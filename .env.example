# Core selection
CHAT_PROVIDER=google
CHAT_MODEL=gemini-2.5-flash
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-2-preview

# Optional generic overrides
CHAT_API_KEY=
CHAT_API_KEY_ENV=
CHAT_API_BASE=
EMBEDDING_API_KEY=
EMBEDDING_API_KEY_ENV=
EMBEDDING_API_BASE=

# Provider-specific fallbacks recognized automatically
GOOGLE_API_KEY=your_google_ai_studio_api_key_here
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Examples:
# CHAT_PROVIDER=anthropic
# CHAT_MODEL=claude-3-5-sonnet-20241022
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
#
# CHAT_PROVIDER=openai-compatible
# CHAT_MODEL=local-model-name
# CHAT_API_BASE=http://localhost:1234/v1
# CHAT_API_KEY=lm-studio
# EMBEDDING_PROVIDER=openai-compatible
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_BASE=http://localhost:1234/v1
# EMBEDDING_API_KEY=lm-studio
#
# CHAT_PROVIDER=litellm
# CHAT_MODEL=openrouter/openai/gpt-4.1-mini
# CHAT_API_KEY_ENV=OPENROUTER_API_KEY
# EMBEDDING_PROVIDER=litellm
# EMBEDDING_MODEL=openai/text-embedding-3-small
